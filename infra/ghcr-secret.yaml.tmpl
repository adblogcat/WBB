# Apply with the GHCR pull token substituted in. Do NOT commit secrets.
# scripts/seed-ghcr-secret.sh handles substitution + kubectl apply.
apiVersion: v1
kind: Secret
metadata:
  name: ghcr-pull
  namespace: webbugbench
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: __DOCKERCONFIG_B64__
